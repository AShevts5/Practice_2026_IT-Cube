APP_NAME=it-cube-backend
APP_ENV=development
DEBUG=true
API_V1_PREFIX=/api/v1
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

DATABASE_URL=postgresql+asyncpg://itcube:itcube@localhost:5432/itcube

SECRET_KEY=dev-only-change-in-production-use-openssl-rand-hex-32
ACCESS_TOKEN_EXPIRE_MINUTES=30
PASSWORD_HASH_SCHEME=bcrypt

OTP_LENGTH=6
OTP_TTL_SECONDS=600
OTP_MAX_ATTEMPTS=5
OTP_RESEND_COOLDOWN_SECONDS=60

SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@itcube.local
SMTP_TLS=false

SMS_PROVIDER=mock
SMS_API_KEY=
SMS_SENDER=IT-CUBE
SMS_TEST_MODE=false

REDIS_URL=redis://localhost:6379/0

EXPORT_MAX_ROWS=10000

OAUTH_FRONTEND_REDIRECT=http://localhost:5173/auth/callback
OAUTH_BACKEND_CALLBACK_BASE=http://localhost:8000/api/v1/auth/oauth

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

YANDEX_CLIENT_ID=
YANDEX_CLIENT_SECRET=

VK_CLIENT_ID=
VK_CLIENT_SECRET=
